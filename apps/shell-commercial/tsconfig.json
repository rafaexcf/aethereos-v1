{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../packages/config-ts/vite-app.json",
  "compilerOptions": {
    "paths": {
      "@aethereos/drivers": ["../../packages/drivers/src/index.ts"],
      "@aethereos/drivers-supabase": [
        "../../packages/drivers-supabase/src/index.ts"
      ],
      "@aethereos/kernel": ["../../packages/kernel/src/index.ts"],
      "@aethereos/scp-registry": ["../../packages/scp-registry/src/index.ts"],
      "@aethereos/ui-shell": ["../../packages/ui-shell/src/index.ts"]
