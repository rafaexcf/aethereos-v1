# =============================================================================
# Comércio Digital — .env.local.example
# Copie para .env.local e preencha com seus valores.
# NUNCA commite .env.local — já está no .gitignore.
# =============================================================================

# Supabase (local dev: use supabase status para obter os valores)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Service Key (somente server-side, nunca expor ao client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase DB URL direto (para Drizzle / drivers-supabase server)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =============================================================================
# Stripe TEST MODE — as chaves abaixo são de TESTE, nunca de produção
# sk_test_ e pk_test_ identificam modo de teste do Stripe
# Obtenha em: https://dashboard.stripe.com/test/apikeys
# =============================================================================

# Chave secreta do Stripe — somente server-side
STRIPE_SECRET_KEY=sk_test_XXXXX

# Chave publicável do Stripe — exposta ao client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXX

# Segredo do webhook Stripe — obtido via stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_XXXXX

# =============================================================================
# Embed — origens autorizadas a embarcarem este app em iframe
# Separadas por espaço. Em dev, localhost é permitido automaticamente.
# =============================================================================
ALLOWED_EMBED_ORIGINS=https://*.aethereos.io https://*.b2baios.com.br
