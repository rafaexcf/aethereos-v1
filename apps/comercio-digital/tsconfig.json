{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../packages/config-ts/next-app.json",
  "compilerOptions": {
    "paths": {
      "@aethereos/drivers": ["../../packages/drivers/src/index.ts"],
      "@aethereos/drivers-supabase": [
        "../../packages/drivers-supabase/src/index.ts"
      ],
      "@aethereos/drivers-supabase/browser": [
        "../../packages/drivers-supabase/src/browser.ts"
      ],
      "@aethereos/kernel": ["../../packages/kernel/src/index.ts"],
      "@aethereos/scp-registry": ["../../packages/scp-registry/src/index.ts"],
      "@aethereos/ui-shell": ["../../packages/ui-shell/src/index.ts"],
      "@aethereos/observability": ["../../packages/observability/src/index.ts"]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "middleware.ts"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
