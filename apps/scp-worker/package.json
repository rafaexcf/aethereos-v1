{
  "name": "@aethereos/scp-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env.local --watch --experimental-specifier-resolution=node dist/main.js",
    "build": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node --env-file=../../.env.local --experimental-specifier-resolution=node dist/main.js",
    "replay": "node --env-file=../../.env.local --experimental-specifier-resolution=node dist/replay-cli.js",
    "test": "vitest run --config vitest.config.ts",
    "test:isolation": "vitest run --config vitest.isolation.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aethereos/drivers": "workspace:*",
    "@aethereos/drivers-supabase": "workspace:*",
    "@aethereos/drivers-nats": "workspace:*",
    "@aethereos/kernel": "workspace:*",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@aethereos/config-eslint": "workspace:*",
    "@aethereos/config-ts": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
