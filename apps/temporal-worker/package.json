{
  "name": "@aethereos/temporal-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env.local --watch dist/main.js",
    "build": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node --env-file=../../.env.local dist/main.js",
    "trigger": "node --env-file=../../.env.local dist/trigger-cli.js",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@aethereos/config-eslint": "workspace:*",
    "@aethereos/config-ts": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
