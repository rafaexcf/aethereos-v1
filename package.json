{
  "name": "aethereos",
  "version": "0.0.0",
  "private": true,
  "description": "Aethereos — OS B2B no navegador. Camada 0 (open source local-first) + Camada 1 (proprietária) + Camada 2 (distribuições verticais).",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . && turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:isolation": "turbo run test:isolation",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:full": "pnpm --filter @aethereos/e2e test:e2e",
    "test:e2e:scp-pipeline": "pnpm --filter @aethereos/e2e test:e2e:scp-pipeline",
    "deps:check": "depcruise --config .dependency-cruiser.cjs packages apps tooling",
    "deps:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot packages apps | dot -T svg > docs/architecture/dependency-graph.svg",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,yaml,yml}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "ci:audit": "pnpm audit --audit-level=high",
    "ci:full": "pnpm typecheck && pnpm lint && pnpm deps:check && pnpm test && pnpm test:isolation && pnpm build",
    "dev:infra": "docker compose -f infra/local/docker-compose.dev.yml up -d nats litellm",
    "dev:scp-worker": "pnpm --filter @aethereos/scp-worker dev",
    "build:scp-worker": "pnpm --filter @aethereos/scp-worker build",
    "dev:infra:down": "docker compose -f infra/local/docker-compose.dev.yml down",
    "dev:llm": "docker compose -f infra/local/docker-compose.dev.yml up -d nats litellm",
    "dev:observability": "docker compose -f infra/local/docker-compose.dev.yml up -d langfuse-postgres langfuse",
    "dev:feature-flags": "docker compose -f infra/local/docker-compose.dev.yml up -d unleash-postgres unleash",
    "dev:otel": "docker compose -f infra/local/docker-compose.dev.yml up -d otel-collector tempo loki prometheus grafana",
    "dev:db": "supabase start && supabase db reset",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:migration": "supabase migration new",
    "seed:dev": "pnpm --filter=@aethereos/seed start",
    "seed:reset": "pnpm --filter=@aethereos/seed start -- --reset",
    "test:smoke": "pnpm --filter=@aethereos/smoke start",
    "setup:env": "bash tooling/setup-env.sh",
    "share:dev": "bash scripts/share-dev.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aethereos/config-eslint": "workspace:*",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "dependency-cruiser": "^16.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "overrides": {
      "happy-dom": ">=20.8.9",
      "serialize-javascript": ">=7.0.5",
      "drizzle-orm": ">=0.45.2",
      "vite@<6.4.2": ">=6.4.2",
      "uuid@<14.0.0": ">=14.0.0",
      "postcss@<8.5.10": ">=8.5.10",
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  }
}
