# Aethereos — variáveis de ambiente locais (copie para .env.local e preencha)
# .env.local está no .gitignore — nunca commite credenciais reais
#
# Uso recomendado (popula automaticamente com valores do Supabase local):
#   cp .env.local.example .env.local
#   pnpm dev:db          # sobe Supabase + aplica migrations
#   pnpm setup:env       # substitui placeholders pelos valores reais
#
# Ou manualmente: copie os valores de `supabase status`

# ---------------------------------------------------------------------------
# Supabase local
# Valores reais: `supabase status -o env`
# IMPORTANTE: usar 127.0.0.1, não localhost — evita CORS entre origens distintas.
# config.toml define site_url=http://127.0.0.1:5174; localhost é origem diferente.
# ---------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# Vite shells (shell-commercial) leem variáveis prefixadas com VITE_
# Devem ter os mesmos valores das chaves Supabase acima.
# Nota: Vite só lê .env.local do diretório do app — não da raiz do monorepo.
# `pnpm setup:env` cria apps/shell-commercial/.env.local automaticamente.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# NATS JetStream (Sprint 1)
# ---------------------------------------------------------------------------
NATS_URL=nats://127.0.0.1:4222

# ---------------------------------------------------------------------------
# LiteLLM gateway (M32)
# Documentação: infra/litellm/config.yaml
# ---------------------------------------------------------------------------
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=sk-dev-litellm-master-key-replace-me

# Providers — pelo menos um deve estar preenchido para LLM calls funcionarem
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me

# ---------------------------------------------------------------------------
# Langfuse observabilidade LLM (M33)
# UI: http://127.0.0.1:3001 | Login: admin@aethereos.local / aethereos-dev-password
# ---------------------------------------------------------------------------
LANGFUSE_BASE_URL=http://127.0.0.1:3001
LANGFUSE_PUBLIC_KEY=pk-lf-dev-aethereos-replace-me
LANGFUSE_SECRET_KEY=sk-lf-dev-aethereos-replace-me

# ---------------------------------------------------------------------------
# Unleash feature flags (M34)
# UI: http://127.0.0.1:4242 | Login: admin / unleash4all
# ---------------------------------------------------------------------------
UNLEASH_URL=http://127.0.0.1:4242/api
UNLEASH_CLIENT_API_TOKEN=default:development.unleash-client-dev-token
UNLEASH_ADMIN_API_TOKEN=*:*.unleash-admin-dev-token

# ---------------------------------------------------------------------------
# OpenTelemetry (M35)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=aethereos-dev

# ---------------------------------------------------------------------------
# Stripe (Sprint 4 — comercio.digital)
# Use apenas chaves test (sk_test_...) em desenvolvimento
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me
