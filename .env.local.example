# Aethereos — variáveis de ambiente locais (copie para .env.local e preencha)
# .env.local está no .gitignore — nunca commite credenciais reais
#
# Uso:
#   cp .env.local.example .env.local
#   # edite .env.local com suas chaves reais

# ---------------------------------------------------------------------------
# LiteLLM gateway (M32)
# Documentação: infra/litellm/config.yaml
# ---------------------------------------------------------------------------
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-dev-litellm-master-key-replace-me

# Providers — pelo menos um deve estar preenchido para LLM calls funcionarem
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me

# ---------------------------------------------------------------------------
# Langfuse observabilidade LLM (M33)
# UI: http://localhost:3001 | Login: admin@aethereos.local / aethereos-dev-password
# ---------------------------------------------------------------------------
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=pk-lf-dev-aethereos-replace-me
LANGFUSE_SECRET_KEY=sk-lf-dev-aethereos-replace-me

# ---------------------------------------------------------------------------
# Unleash feature flags (M34)
# UI: http://localhost:4242 | Login: admin / unleash4all
# ---------------------------------------------------------------------------
UNLEASH_URL=http://localhost:4242/api
UNLEASH_CLIENT_API_TOKEN=default:development.unleash-client-dev-token
UNLEASH_ADMIN_API_TOKEN=*:*.unleash-admin-dev-token

# ---------------------------------------------------------------------------
# OpenTelemetry (M35)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=aethereos-dev

# ---------------------------------------------------------------------------
# Supabase local (Sprint 1/3)
# ---------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-with-supabase-local-anon-key
SUPABASE_SERVICE_KEY=replace-with-supabase-local-service-key

# ---------------------------------------------------------------------------
# NATS JetStream (Sprint 1)
# ---------------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# Stripe (Sprint 4 — comercio.digital)
# Use apenas chaves test (sk_test_...) em desenvolvimento
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace-me
