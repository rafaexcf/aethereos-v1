{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@aethereos/config-ts/library-build",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "references": [
    { "path": "../drivers/tsconfig.build.json" },
    { "path": "../scp-registry/tsconfig.build.json" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
