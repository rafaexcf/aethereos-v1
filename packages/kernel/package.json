{
  "name": "@aethereos/kernel",
  "version": "0.0.0",
  "private": true,
  "description": "Kernel do Aethereos — núcleo agnóstico de implementação (Driver Model, SCP, audit, permissions)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@aethereos/config-ts": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@aethereos/drivers": "workspace:*",
    "@aethereos/scp-registry": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "zod": "^3.24.0"
  },
  "license": "BUSL-1.1"
}
