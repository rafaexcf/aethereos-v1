{
  "name": "@aethereos/ui-shell",
  "version": "0.0.0",
  "private": true,
  "description": "Componentes de UI compartilhados entre Camada 0 e Camada 1 do shell Aethereos",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "default": "./src/components/*/index.tsx"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "default": "./src/primitives/index.ts"
    },
    "./theme": {
      "types": "./dist/theme/tokens.d.ts",
      "default": "./src/theme/tokens.ts"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./src/hooks/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@aethereos/config-ts": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "license": "BUSL-1.1"
}
